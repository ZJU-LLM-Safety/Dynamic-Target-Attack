# Copy this file to `.env` and fill in the providers you need.

OPENAI_API_KEY=
OPENAI_API_BASE=

ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=

GOOGLE_API_KEY=
GOOGLE_API_BASE=

DASHSCOPE_API_KEY=
TOGETHER_API_KEY=

# Optional local overrides for datasets and outputs.
DTA_DATA_DIR=./data
DTA_LOG_DIR=./logs

# Optional model overrides if you use local mirrors instead of Hugging Face ids.
DTA_MODEL_LLAMA3=meta-llama/Meta-Llama-3-8B-Instruct
DTA_MODEL_QWEN25=Qwen/Qwen2.5-7B-Instruct
DTA_MODEL_MISTRALV03=mistralai/Mistral-7B-Instruct-v0.3
DTA_MODEL_GEMMA7B=google/gemma-7b-it
DTA_MODEL_VICUNA15=lmsys/vicuna-7b-v1.5
DTA_GPTFUZZ_MODEL=hubert233/GPTFuzz
DTA_LLAMAGUARD3_MODEL=meta-llama/Llama-Guard-3-8B
DTA_WILDGUARD_MODEL=allenai/wildguard
